# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?appName=<app>
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# JWT Secrets — must be at least 32 chars each
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# SMTP (leave empty for dev — uses Ethereal test accounts)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# eSewa Payment (sandbox defaults used if empty)
ESEWA_PAYMENT_URL=https://rc-epay.esewa.com.np/api/epay/main/v2/form
ESEWA_STATUS_URL=https://uat.esewa.com.np/api/epay/transaction/status/
ESEWA_LIVE=false

# Khalti Payment (sandbox defaults used if empty)
KHALTI_LIVE=false
KHALTI_INITIATE_URL=https://dev.khalti.com/api/v2/epayment/initiate/
KHALTI_LOOKUP_URL=https://dev.khalti.com/api/v2/epayment/lookup/

# Domain
CLIENT_BASE_DOMAIN=localhost:3000
# COOKIE_DOMAIN=.yourdomain.com  (production only)
